// General configuration for Janus Gateway
// Location: /opt/janus/etc/janus/janus.jcfg
// Documentation: https://janus.conf.meetecho.com/docs/

general: {
    // Session configuration
    configs_folder = "/opt/janus/etc/janus"
    plugins_folder = "/opt/janus/lib/janus/plugins"
    transports_folder = "/opt/janus/lib/janus/transports"
    events_folder = "/opt/janus/lib/janus/events"
    loggers_folder = "/opt/janus/lib/janus/loggers"
    
    // Logging
    debug_level = 4                     // 0=fatal, 1=error, 2=warn, 3=info, 4=verb, 5=huge, 6=dbg, 7=log
    debug_timestamps = true
    debug_colors = false
    debug_locks = false
    
    // Admin/Monitor interface
    admin_secret = "janusoverlord"      // CHANGE THIS IN PRODUCTION!
    
    // API/WebSocket settings
    api_secret = "janusrocks"           // CHANGE THIS IN PRODUCTION!
    token_auth = false                  // Set to true and configure tokens for production
    token_auth_secret = "yourtokensecret"
    
    // Session settings
    session_timeout = 60                // Timeout for inactive sessions (seconds)
    reclaim_session_timeout = 0         // Grace period before reclaiming (0 = immediate)
    
    // Network configuration
    // IMPORTANT: Set this to your EC2 public IP or elastic IP
    nat: {
        stun_server = "stun.l.google.com"
        stun_port = 19302
        nice_debug = false
        full_trickle = true
        ice_lite = false
        ice_tcp = true
        
        // 1:1 NAT mapping - REPLACE WITH YOUR PUBLIC IP
        # nat_1_1_mapping = "YOUR_EC2_PUBLIC_IP_HERE"
        
        // For EC2 with public IP, uncomment and set:
        # nat_1_1_mapping = "54.123.456.789"
        
        // Keep alive for NAT bindings
        keepalive_conncheck = false
    }
    
    // TURN server configuration (optional but recommended for production)
    # turn_server = "turn:turn.example.com:3478"
    # turn_user = "username"
    # turn_pwd = "password"
    # turn_type = "udp"  // udp, tcp, or tls
    
    // Media configuration
    media: {
        ipv6 = false
        max_nack_queue = 1000
        rtp_port_range = "10000-10500"  // Port range for RTP/RTCP (configure firewall!)
        
        // DSCP marking for QoS (optional)
        # dscp_ef = 46    // Expedited Forwarding
    }
    
    // Recording path
    recordings_tmp_ext = "tmp"
}

// Certificate configuration for HTTPS/WSS/DTLS
certificates: {
    # cert_pem = "/opt/janus/share/janus/certs/mycert.pem"
    # cert_key = "/opt/janus/share/janus/certs/mycert.key"
    # cert_pwd = "secretpassphrase"
    dtls_accept_selfsigned = true       // Accept self-signed certs (dev only!)
    dtls_ciphers = "DEFAULT:!NULL:!aNULL:!SHA256:!SHA384:!aECDH:!AESGCM+AES256:!aPSK"
}

// Event handlers
events: {
    broadcast = true
    combine_media_stats = false
    event_loops = 8
}
