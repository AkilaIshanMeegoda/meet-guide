# Docker Compose Environment Configuration
# Copy to .env and customize for your environment

# Janus Configuration
PUBLIC_IP=YOUR_EC2_PUBLIC_IP_HERE
JANUS_API_SECRET=change_this_secret_12345
JANUS_ADMIN_SECRET=change_this_admin_secret_67890

# Recorder Configuration
RECORDER_PORT=3001
TRANSCRIBE_ENDPOINT=http://transcribe:3000/transcribe

# Transcribe Service
TRANSCRIBE_PORT=3000

# Paths (host system)
RECORDINGS_PATH=/var/recordings
TRANSCRIBE_JOBS_PATH=/var/transcribe/jobs

# Logging
LOG_LEVEL=info
